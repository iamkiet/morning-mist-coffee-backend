NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgres://postgres:postgres@localhost:5432/app

AUTH_JWT_SECRET=replace-with-32-bytes-base64url-string-from-the-command-in-readme
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d

CORS_ORIGINS=http://localhost:3000

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
USER_REGISTRATION_KEY=replace-with-32-bytes-base64url-string-from-the-command-above

AUTH_LOGIN_RATE_MAX=5
AUTH_LOGIN_RATE_WINDOW=1 minute

# Set true in production (HTTPS), false in dev (http://localhost)
COOKIE_SECURE=false
# Use 'none' + COOKIE_SECURE=true in production for cross-domain (different frontend/backend hosts)
# Use 'lax' for same-domain or local dev
COOKIE_SAME_SITE=lax

# Set true in dev/staging to return real 500 messages; false in production to return generic "Internal server error"
EXPOSE_INTERNAL_ERRORS=true
